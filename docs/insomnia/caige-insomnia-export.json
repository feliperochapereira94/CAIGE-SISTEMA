    {
      "_id": "req_login_supervisor",
      "parentId": "fld_auth",
      "name": "POST /api/auth/login - Supervisor (200)",
      "description": "Faz login como supervisor e salva jwt_token no ambiente.",
      "method": "POST",
      "url": "{{ _.base_url }}/api/auth/login",
      "body": { "mimeType": "application/json", "text": "{\n  \"email\": \"{{ _.supervisor_email }}\",\n  \"password\": \"{{ _.supervisor_password }}\"\n}" },
      "parameters": [],
      "headers": [{ "name": "Content-Type", "value": "application/json" }],
      "authentication": {},
      "metaSortKey": -1000,
      "isPrivate": false,
      "pathParameters": [],
      "afterResponseScript": "insomnia.test('status 200', () => { insomnia.expect(insomnia.response.code).to.eql(200); });\nconst body = insomnia.response.json();\ninsomnia.test('has accessToken', () => { insomnia.expect(body.accessToken).to.not.eql(undefined); });\ninsomnia.test('tokenType is Bearer', () => { insomnia.expect(body.tokenType).to.eql('Bearer'); });\nif (body.accessToken) { insomnia.environment.set('jwt_token', body.accessToken); }",
      "settingStoreCookies": true, "settingSendCookies": true, "settingDisableRenderRequestBody": false,
      "settingEncodeUrl": true, "settingRebuildPath": true, "settingFollowRedirects": "global",
